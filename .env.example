# Template for the gitignored local .env — variable names and placeholders only.
# Real values: Vercel env vars (prod/preview) or your local .env. Never commit secrets.

# Application environment: dev | preview | prod. Controls OpenAPI docs exposure
# (dev only) and, later, the preview mutation lockout.
APP_ENV=dev

# Postgres connection string. Local: the Supabase CLI stack (port 54322).
# Prod: the Supabase transaction-mode pooler URL (port 6543).
# Unused until the DB workstream lands.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Origin of the FastAPI library API. When set, getGames()/getWishlist() read
# from the API (backed by the local Supabase DB); when unset/empty, they fall
# back to the CSV files at the repo root. Local dev value:
# LIBRARY_API_ORIGIN=http://127.0.0.1:8000

# --- Phase 2+ (Supabase auth) ---
# NEXT_PUBLIC_ vars are inlined into the browser bundle by design (anon key +
# project URL are public); the service-role key is server-only and must never
# get the NEXT_PUBLIC_ prefix.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
