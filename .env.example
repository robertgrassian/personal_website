# Template for the gitignored local .env — variable names and placeholders only.
# Real values: Vercel env vars (prod/preview) or your local .env. Never commit secrets.

# Application environment: dev | preview | prod. Controls OpenAPI docs exposure
# (dev only) and, later, the preview mutation lockout.
APP_ENV=dev

# Postgres connection string. Local: the Supabase CLI stack (port 54322).
# Prod: the Supabase transaction-mode pooler URL (port 6543).
# Unused until the DB workstream lands.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Origin of the FastAPI library API — REQUIRED. getGames()/getWishlist() read
# exclusively from the API (backed by Postgres); the CSV fallback was retired,
# so an unset value fails the build/render loudly. Local dev value below; in
# Vercel set it to the production domain (https://rgrassian.com).
LIBRARY_API_ORIGIN=http://127.0.0.1:8000

# --- Phase 2a (Supabase auth) ---
# Get local values from `supabase status -o env` (API_URL, ANON_KEY,
# SERVICE_ROLE_KEY). All local-stack values are published CLI defaults.

# Backend token verification. The current CLI stack signs ES256 and publishes
# JWKS, so local uses the JWKS path exactly like prod will. Set the JWKS URL;
# leave SUPABASE_JWT_SECRET unset (it's a legacy HS256 fallback only).
# SUPABASE_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json
# SUPABASE_AUTH_ISSUER=http://127.0.0.1:54321/auth/v1

# Server-only: GoTrue Admin API base + service-role key (over-cap auth-user
# cleanup, account deletion). The service-role key bypasses all authorization —
# never give it the NEXT_PUBLIC_ prefix.
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Signup cap (spec decision #13): profile creation refuses past this count.
# MAX_USERS=100

# --- Phase 3 (IGDB proxy) ---
# Twitch application credentials (IGDB authenticates via Twitch OAuth) for
# GET /api/py/igdb/search. Same app registration fetch-covers.ts used:
# https://dev.twitch.tv/console → your app → Client ID / Client Secret.
# Server-side only; unset → the search endpoint answers 503.
# TWITCH_CLIENT_ID=your-twitch-client-id
# TWITCH_CLIENT_SECRET=your-twitch-client-secret

# Frontend (@supabase/ssr). NEXT_PUBLIC_ vars are inlined into the browser
# bundle by design — the anon key + project URL are public; safe to expose.
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
